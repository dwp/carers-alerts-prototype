    }
})

router.post('/' + version + '/dashboards/teams-remove-team-member', function (req, res) {

    if (req.session.data['deleteUser'] == 'yes') {

        let x = req.session.data['remove'];
        let temporaryArray = [];
        let teamName = req.session.data['teamName']
        temporaryArray = req.session.data[teamName]
        temporaryArray.splice(x, 1);
        req.session.data[teamName] = temporaryArray
        req.session.data['remove'] = null;
    }
    res.redirect('teams-manage-team?banner=userRemoved')

})

router.post('/' + version + '/dashboards/teams-remove-team', function (req, res) {
    if (req.session.data['deleteUser'] == 'yes') {

        let x = req.session.data['remove'];
        let temporaryArray = [];
        let teamName = req.session.data['teamName']
        temporaryArray = req.session.data['teams']
        temporaryArray.splice(x, 1);
        req.session.data['teams'] = temporaryArray;
        req.session.data[teamName] = null
        req.session.data['remove'] = null
        res.redirect('teams-my-teams?banner=teamRemove')
    }
    else if (req.session.data['deleteUser'] == 'no') {
        res.redirect('teams-my-teams')
    }
})


router.post('/' + version + '/dashboards/teams-view-team*', function (req, res) {
    let startDate = new Date(req.session.data['teamViewStart-year'] + "-" + req.session.data['teamViewStart-month'] + "-" + req.session.data['teamViewStart-day'])
    let endDate = new Date(req.session.data['teamViewEnd-year'] + "-" + req.session.data['teamViewEnd-month'] + "-" + req.session.data['teamViewEnd-day'])
    req.session.data['teamViewStart'] = startDate
    req.session.data['teamViewEnd'] = endDate

    // Use this later to change the data based on the days in the period
    // const diffInTime = Math.abs(endDate - startDate);
    // const diffInDays = Math.floor(diffInTime / (1000 * 60 * 60 * 24)); 
    // req.session.data['teamViewDays'] = diffInDays

    let totalAllocated = 0;
    let totalClosed = 0;

    for (members in req.session.data[req.session.data['teamName']]) {  
        totalClosed += req.session.data[req.session.data['teamName']][members].clearedTasks
        totalAllocated += req.session.data[req.session.data['teamName']][members].allocatedTasks
    }
    req.session.data['totalClosed'] = totalClosed
    req.session.data['totalAllocated'] = totalAllocated

    res.redirect('teams-view-team-overview');

})

