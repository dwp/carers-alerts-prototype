router.get('/' + version + '/dashboards/teams-my-teams', function (req, res) {

    let lastWorkingDay = new Date();

    if (lastWorkingDay.getDay() == 1) {
        lastWorkingDay.setDate(lastWorkingDay.getDate() - 1);
    }
    else {
        lastWorkingDay.setDate(lastWorkingDay.getDate() - 1);
    }

    lastWorkingDay.setDate(lastWorkingDay.getDate() - 1);


    req.session.data['teamViewStart-day'] = lastWorkingDay.getDate()
    req.session.data['teamViewStart-month'] = lastWorkingDay.getMonth()
    req.session.data['teamViewStart-year'] = lastWorkingDay.getFullYear()

    res.render('/' + version + '/dashboards/teams-my-teams')
})


router.post('/' + version + '/dashboards/teams-new-team-name*', function (req, res) {

    let tempTeamsArray = [];
    if (req.session.data['teams']) {
        tempTeamsArray = req.session.data['teams'];
    }
    let teamName = req.session.data['teamName'];

    tempTeamsArray.push(teamName);
    req.session.data['teams'] = tempTeamsArray;

    res.redirect('teams-manage-team')
})

router.post('/' + version + '/dashboards/teams-manage-team*', function (req, res) {

    if (req.session.data['user']) {
        let tempTeamArray = [];
