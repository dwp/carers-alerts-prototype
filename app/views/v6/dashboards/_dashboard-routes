const govukPrototypeKit = require('govuk-prototype-kit')
const router = govukPrototypeKit.requests.setupRouter()

let version = "v6";

router.get('/'+version + '/setupData', function (req, res) {
    
    let today= new Date();
    let yesterday = new Date(today.setDate(today.getDate() - 1));

    var prevMonday = new Date();
    prevMonday.setDate(prevMonday.getDate() - 7);
    prevMonday.setDate(prevMonday.getDate() - (prevMonday.getDay() + 6) % 7);

    let prevSunday = new Date(prevMonday)
    prevSunday.setDate(prevSunday.getDate() + 6)

    let weekStart = new Date()
    weekStart.setDate(yesterday.getDate() - 6)
    
    let monthStart = new Date()
    monthStart.setMonth(yesterday.getMonth()-1)

    req.session.data['yesterday'] = yesterday;
    req.session.data['previousMonday'] = prevMonday;
    req.session.data['previousSunday'] = prevSunday;
    req.session.data['monthStart'] = monthStart;
    req.session.data['weekStart'] = weekStart;

    res.redirect('dashboards/service-data')
})

router.post('/' + version + '/dashboards/service-data', function (req, res) {
    res.redirect('service-data')
})


router.post('/' + version + '/dashboards/teams-new-team-name', function (req, res) {

    let tempTeamsArray = [];
    if (req.session.data['teams']) {
        tempTeamsArray = req.session.data['teams'];
    }
    let teamName = req.session.data['teamName'];

    tempTeamsArray.push(teamName);
    req.session.data['teams'] = tempTeamsArray;

    res.redirect('teams-manage-team')
})

router.post('/' + version + '/dashboards/teams-manage-team*', function (req, res) {

    if (req.session.data['user']) {
        let tempTeamArray = [];
        let teamName = req.session.data['teamName'];
        if (req.session.data[teamName]) {
            tempTeamArray = req.session.data[teamName]
        }

        let x = req.session.data["user"];

        req.session.data["tempName"] = req.session.data['users'][x].firstName + " " + req.session.data['users'][x].lastName

        for (let i = 0; i < tempTeamArray.length; i++) {

            if (tempTeamArray[i].email == req.session.data['users'][x].email) {
